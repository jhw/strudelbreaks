node_modules/
.DS_Store
tmp/
*.log

# Python
.venv/
venv/
__pycache__/
*.pyc

# Pulumi: Pulumi.yaml is committed; per-stack files are
# generated by `pulumi stack init` per-environment and can carry
# encrypted secrets. Single-developer scope — keep them local.
infra/*/Pulumi.*.yaml
!infra/*/Pulumi.yaml
infra/*/venv/

# Local secrets (sourced before deploy)
config/setenv.local.sh
